# Target environment: prod | preprod | staging  (default: prod)
# Usage: ENV=prod npx playwright test --project=api
ENV=prod

# Base URL for UI tests
BASE_URL=https://useinsider.com
GATEWAY_BASE_URL=https://useinsider.com
HEADLESS=false

# Auth credentials
PLAYWRIGHT_USER_EMAIL=
PLAYWRIGHT_USER_PASSWORD=

# UCD / Atrium
#   LOCAL_KUBE=0 → atrium.useinsider.com     (production)
#   LOCAL_KUBE=1 → atrium.insidethekube.com  (kube cluster)
LOCAL_KUBE=0
UCD_API_KEY=secret

# Shopify store tokens
SHOPIFY_STORE_1_TOKEN=
SHOPIFY_STORE_2_TOKEN=
SHOPIFY_STORE_3_TOKEN=
SHOPIFY_STORE_4_TOKEN=
SHOPIFY_STORE_5_TOKEN=
SHOPIFY_STORE_6_TOKEN=
PROD_SHOPIFY_LIVE_SYNC_TOKEN=
SHOPIFY_AUTOMATION_STORE_TOKEN=
INSDEV_MARKET_AUTOMATION_TOKEN=
